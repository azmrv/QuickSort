# ==========================================
# Dependency Directories & Frontend Locks
# ==========================================
node_modules/

# Optional npm, yarn and bun cache directory
.npm/
.yarn/

# npm, yarn and bun lock files (Kept ignored per your preference)
package-lock.json
yarn.lock
bun.lockb

# Output of 'npm pack'
*.tgz

# ==========================================
# Rust & Tauri Core Build Rules
# ==========================================
# Rust compiled folders
target/

# Tauri compiles its nested Rust code here (Essential additions)
src-tauri/target/
/src-tauri/target/

# For Tauri apps (executables), you should ideally track Cargo.lock.
# If you prefer to ignore it, uncomment the line below:
# Cargo.lock

# Tauri examples /gen directory
/examples/**/src-tauri/gen/
/bench/**/src-tauri/gen/

# Project-specific test files
streaming_example_test_video.mp4

